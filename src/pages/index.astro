---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import CharacterCard from "../components/CharacterCard.astro";

const guides = await getCollection("guides");
const boss = await getCollection("boss");
const characters = await getCollection("characters");

// Recent guides (excluding character_db / weapon_db / tier_list / faq)
const recent = [
  ...guides.map((e) => ({ ...e, href: `/guides/${e.slug}` })),
  ...boss.map((e)   => ({ ...e, href: `/boss/${e.slug}` })),
]
  .sort((a, b) => {
    const da = a.data.published_at ? Date.parse(a.data.published_at) : 0;
    const db = b.data.published_at ? Date.parse(b.data.published_at) : 0;
    return db - da;
  })
  .slice(0, 6);

// Top character cards (S+ / S only, by tier order). Two safeguards:
//  (1) filter out noindex'd / low-tier pages — they're hidden from search,
//      they shouldn't be promoted on the homepage either (matches sitemap
//      NOINDEX_BELOW = 6.0).
//  (2) dedupe by character_id, keeping the best qa_score copy — the
//      pipeline occasionally produces two articles for the same character
//      (e.g. Fu Xuan ×2), and the homepage was rendering both as separate
//      Featured cards. Topic-signature dedup in KeywordSelector blocks new
//      dups going forward; this handles the historical ones.
const TIER_ORDER: Record<string, number> = { "S+": 0, "S": 1, "A": 2, "B": 3, "C": 4 };
const NOINDEX_BELOW = 6.0;
const byCharacterId = new Map<string, any>();
for (const c of characters) {
  const qa = c.data.qa_score;
  if (typeof qa === "number" && qa < NOINDEX_BELOW) continue;
  const id = c.data.character_data?.character_id || c.slug;
  const prev = byCharacterId.get(id);
  if (!prev || (qa ?? 0) > (prev.data.qa_score ?? 0)) byCharacterId.set(id, c);
}
const featuredCharacters = Array.from(byCharacterId.values())
  .map((c) => ({
    slug: c.slug,
    title: c.data.title,
    characterId: c.data.character_data?.character_id,
    rarity: c.data.character_data?.rarity ?? null,
    element: c.data.character_data?.element,
    weaponType: c.data.character_data?.weapon_type,
    tier: c.data.character_data?.tier,
    role: c.data.character_data?.role,
    heroImage: c.data.hero_image,
  }))
  .sort((a, b) => (TIER_ORDER[a.tier ?? "C"] ?? 9) - (TIER_ORDER[b.tier ?? "C"] ?? 9))
  .slice(0, 6);

// WebSite + ItemList JSON-LD so Google rich results have something to chew
// on for the root page.
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      url: "https://ntecodex.com/",
      name: "Gacha Codex",
      description:
        "Multi-game gacha strategy hub — tier lists, builds, banners and boss guides for Wuthering Waves, ZZZ, HSR, Genshin, NTE and more.",
      inLanguage: "en",
      publisher: { "@type": "Organization", name: "Gacha Codex" },
      potentialAction: {
        "@type": "SearchAction",
        target: "https://ntecodex.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "ItemList",
      name: "Featured characters",
      itemListElement: featuredCharacters.slice(0, 6).map((c, i) => ({
        "@type": "ListItem",
        position: i + 1,
        url: `https://ntecodex.com/characters/${c.slug}/`,
        name: c.title,
      })),
    },
  ],
};
---

<BaseLayout
  title="Gacha Codex — Tier Lists, Builds & Strategy for Popular Gacha Games"
  description="Daily-updated guides for Wuthering Waves, Zenless Zone Zero, Honkai: Star Rail, Genshin Impact, Neverness to Everness and more. Tier lists, builds, banners, boss strategies."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8 overflow-hidden bg-hero-gradient">
    <div class="container-page py-10 md:py-16 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-300">
        Multi-game gacha strategy hub
      </p>
      <h1 class="mt-3 mx-auto max-w-3xl bg-gradient-to-b from-white to-primary-200 bg-clip-text text-transparent">
        Master every gacha game.
      </h1>
      <p class="mt-4 mx-auto max-w-2xl text-lg text-gray-300">
        Tier lists, builds, banners and boss strategies for popular gacha games — updated daily by the editorial team.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href="/tier-list"
           class="rounded-lg bg-primary-600 px-5 py-2.5 font-semibold text-white shadow-glow-primary no-underline hover:bg-primary-500">
          See Tier Lists
        </a>
        <a href="/guides"
           class="rounded-lg border border-white/10 px-5 py-2.5 font-semibold text-gray-200 no-underline hover:bg-white/5">
          Browse Guides
        </a>
      </div>
    </div>
  </section>

  <!-- Featured characters -->
  <section class="mt-16">
    <div class="flex items-end justify-between">
      <h2 class="m-0">Featured Characters</h2>
      <a href="/characters" class="text-sm text-primary-300 hover:text-primary-200 no-underline">View all →</a>
    </div>
    {featuredCharacters.length > 0 ? (
      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {featuredCharacters.map((c) => <CharacterCard {...c} />)}
      </div>
    ) : (
      <p class="mt-4 text-gray-500">Character database is just getting started — check back soon.</p>
    )}
  </section>


  <!-- Recent articles -->
  <section class="mt-16">
    <div class="flex items-end justify-between">
      <h2 class="m-0">Latest Guides</h2>
      <a href="/guides" class="text-sm text-primary-300 hover:text-primary-200 no-underline">All guides →</a>
    </div>
    {recent.length > 0 ? (
      <div class="mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {recent.map((e) => (
          <ArticleCard
            href={e.href}
            title={e.data.title}
            articleType={e.data.article_type}
            qaScore={e.data.qa_score}
            wordCount={e.data.word_count}
            publishedAt={e.data.published_at}
            heroImage={e.data.hero_image}
          />
        ))}
      </div>
    ) : (
      <p class="mt-4 text-gray-500">No guides yet.</p>
    )}
  </section>
</BaseLayout>
