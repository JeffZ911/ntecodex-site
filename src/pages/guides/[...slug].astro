---
import { getCollection, type CollectionEntry } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";

export async function getStaticPaths() {
  const all = await getCollection("guides");
  return all.map((entry) => {
    // PublishAgent writes reroll articles to `guides/reroll/<slug>` with
    // published_url=/guides/reroll/<slug>. Astro auto-slug strips that
    // subdirectory, so derive the catch-all param from published_url
    // (after `/guides/`) when present.
    const purl = entry.data.published_url || "";
    const m = purl.match(/^\/guides\/(.+)\/?$/);
    const param = m ? m[1].replace(/\/$/, "") : entry.slug;
    return { params: { slug: param }, props: { entry } };
  });
}

interface Props { entry: CollectionEntry<"guides"> }
const { entry } = Astro.props;
const { Content } = await entry.render();

// Guides may live in subfolders (e.g. guides/reroll/). Slot the
// subfolder name into the breadcrumb so /guides/reroll/<slug> reads
// as Home > Guides > Reroll > <title>.
const SUBFOLDER_LABELS: Record<string, string> = {
  reroll: "Reroll",
};
const subKey = entry.slug.includes("/") ? entry.slug.split("/", 1)[0] : null;
const subLabel = subKey ? SUBFOLDER_LABELS[subKey] : null;
const crumbs = [
  { href: "/", label: "Home" },
  { href: "/guides", label: "Guides" },
  ...(subLabel && subKey ? [{ href: `/guides/${subKey}`, label: subLabel }] : []),
  { label: entry.data.title },
];
---

<ArticleLayout
  title={entry.data.title}
  publishedAt={entry.data.published_at}
  qaScore={entry.data.qa_score}
  wordCount={entry.data.word_count}
  articleType={entry.data.article_type}
  heroImage={entry.data.hero_image}
  sources={entry.data.sources}
  slug={entry.slug}
  crumbs={crumbs}
>
  <Content />
</ArticleLayout>
