---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — NTE Codex" description="How to reach the NTE Codex team.">
  <h1>Contact</h1>
  <div class="prose-game max-w-prose">
    <p>
      Found a factual error, a broken link, or content that needs taking down?
      Drop us a line.
    </p>
    <ul>
      <li><strong>General &amp; corrections:</strong> <a href="mailto:hello@ntecodex.com">hello@ntecodex.com</a></li>
      <li><strong>Privacy / data requests:</strong> <a href="mailto:privacy@ntecodex.com">privacy@ntecodex.com</a></li>
      <li><strong>DMCA / takedown:</strong> <a href="mailto:legal@ntecodex.com">legal@ntecodex.com</a></li>
    </ul>
    <p>
      Please include the URL of the page in question and a short description.
      We aim to respond within 3 business days.
    </p>
  </div>
</BaseLayout>
