---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import TierTable from "../components/TierTable.astro";
import ArticleCard from "../components/ArticleCard.astro";

const characters = await getCollection("characters");

// Editorial tier-list articles (article_type='tier_list') are stored in the
// `tier-list-source` content collection and aggregated below. They do NOT
// get their own pages — they're embedded here for readers who want the
// long-form ranking commentary alongside the auto-aggregated character grid.
const tierListArticles = await getCollection("tier-list-source");
const editorialItems = tierListArticles
  .map((e) => ({
    href: `#editorial-${e.slug}`,
    title: e.data.title,
    articleType: "tier_list",
    qaScore: e.data.qa_score,
    wordCount: e.data.word_count,
    publishedAt: e.data.published_at,
    heroImage: e.data.hero_image,
    body: e,
  }))
  .sort((a, b) => Date.parse(b.publishedAt || "") - Date.parse(a.publishedAt || ""));
// Mirror sitemap policy: low-tier (qa < 6.0) entries are noindex'd, so
// don't promote them on the tier list either.
const NOINDEX_BELOW = 6.0;
const entries = characters
  .filter((c) => !(typeof c.data.qa_score === "number" && c.data.qa_score < NOINDEX_BELOW))
  .map((c) => ({
    slug: c.slug,
    title: c.data.title,
    characterId: c.data.character_data?.character_id,
    rarity: c.data.character_data?.rarity ?? null,
    element: c.data.character_data?.element,
    weaponType: c.data.character_data?.weapon_type,
    tier: c.data.character_data?.tier,
    role: c.data.character_data?.role,
    heroImage: c.data.hero_image,
    game: c.data.game || "nte",
  }));

// Build filter chips dynamically from what's actually in the dataset.
// Avoids static role lists drifting from real data (e.g. listing "Healer"
// on a multi-game page where no character has that role yet).
const GAME_LABEL: Record<string, string> = {
  nte: "NTE", hsr: "HSR", genshin: "Genshin", zzz: "ZZZ", wuwa: "WuWa",
};
const presentGames = Array.from(new Set(entries.map((e) => e.game))).sort();
const presentRoles = Array.from(
  new Set(entries.flatMap((e) => e.role || []).map((r) => r.trim()))
).filter(Boolean).sort();

// ── Internal-link equity for trend pages. The tier-list is the most-crawled,
// highest-authority page on the site (it carries the impression spikes). Trend
// articles (news/boss/guides/weapons) win a temporary freshness ranking, then
// fall back to baseline once the freshness boost expires — partly because they
// sit "naked" with few inbound internal links. Linking the most recent ones
// FROM this hub passes crawl equity + authority so they hold rank after the
// freshness window closes (turns the impression sawtooth into a rising floor).
const indexable = (e: any) =>
  !(typeof e.data.qa_score === "number" && e.data.qa_score < NOINDEX_BELOW);
const guideCollections: { name: any; prefix: string }[] = [
  { name: "news", prefix: "/news" },
  { name: "guides", prefix: "/guides" },
  { name: "boss", prefix: "/boss" },
  { name: "weapons", prefix: "/weapons" },
];
const recentGuides = (
  await Promise.all(
    guideCollections.map(async ({ name, prefix }) => {
      const items = await getCollection(name).catch(() => []);
      return items.filter(indexable).map((e: any) => ({
        href: `${prefix}/${e.slug}/`,
        title: e.data.title,
        publishedAt: e.data.published_at,
      }));
    })
  )
)
  .flat()
  .filter((g) => g.title && g.href)
  .sort((a, b) => Date.parse(b.publishedAt || "") - Date.parse(a.publishedAt || ""))
  .slice(0, 12);

// Freshness signal (dateModified + visible "Last updated") must reflect EVERY
// real update to this hub. ntecodex only generates comparison/faq articles
// (tier_list/news/etc. are blacklisted as too-fabrication-prone for a new
// game), so new character/tier-list-source entries are rare and the hub would
// otherwise advertise a stale dateModified for weeks. But every patch DOES
// produce fresh comparison/faq guides, which this hub now showcases in its
// "Latest Guides" block — so the freshest guide it links IS a genuine update
// to this page. Take the max published_at across characters, tier-list-source,
// AND the newest showcased guide → the hub re-enters Google's freshness window
// on each patch wave, honestly (its content really did change).
const lastUpdated = [
  ...characters.map((c) => c.data.published_at),
  ...tierListArticles.map((e) => e.data.published_at),
  recentGuides[0]?.publishedAt,
]
  .filter(Boolean)
  .sort()
  .pop();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "NTE Tier List — Best Characters Ranked",
  url: "https://ntecodex.com/tier-list",
  about: {
    "@type": "VideoGame",
    name: "Neverness to Everness",
  },
  dateModified: lastUpdated,
};
---

<BaseLayout
  title={`Gacha Tier List (${new Date().toLocaleString("en-US", { month: "long", year: "numeric", timeZone: "UTC" })}) — NTE, HSR, Genshin, ZZZ & WuWa Ranked`}
  description={`${entries.length} characters ranked S+ to C across Neverness to Everness, Honkai Star Rail, Genshin Impact, ZZZ and Wuthering Waves — updated for the current banners and patches.`}
  jsonLd={jsonLd}
>
  <Breadcrumb crumbs={[{ href: "/", label: "Home" }, { label: "Tier List" }]} />
  <div class="mb-6">
    <h1 class="m-0">Tier List</h1>
    <p class="mt-2 text-gray-400">
      Last updated: <span class="text-white">{lastUpdated ? new Date(lastUpdated).toISOString().slice(0, 10) : "—"}</span>
      · Aggregated from <span class="text-white">{entries.length}</span> character {entries.length === 1 ? "entry" : "entries"}.
    </p>
  </div>

  {/* Filter chips — vanilla-JS client-side filter, no framework cost.
      Game filter is multi-select (toggle on/off); role filter is
      single-select (one role at a time, or All). Cards that don't
      match either are hidden via the [data-tier-entry] data attrs
      set in TierTable. */}
  <div class="mb-6 space-y-3" data-tier-filters>
    {presentGames.length > 1 && (
      <div class="flex flex-wrap items-center gap-2 text-sm">
        <span class="mr-1 text-xs uppercase tracking-wider text-gray-500">Game</span>
        {presentGames.map((g) => (
          <button
            type="button"
            data-game-chip
            data-value={g}
            class="rounded-md border border-white/10 bg-primary-600 px-3 py-1.5 text-white"
          >
            {GAME_LABEL[g] || g.toUpperCase()}
          </button>
        ))}
      </div>
    )}
    {presentRoles.length > 0 && (
      <div class="flex flex-wrap items-center gap-2 text-sm">
        <span class="mr-1 text-xs uppercase tracking-wider text-gray-500">Role</span>
        <button
          type="button" data-role-chip data-value="all"
          class="rounded-md border border-white/10 bg-primary-600 px-3 py-1.5 text-white"
        >All</button>
        {presentRoles.map((r) => (
          <button
            type="button"
            data-role-chip
            data-value={r.toLowerCase()}
            class="rounded-md border border-white/10 bg-bg-soft px-3 py-1.5 text-gray-400 hover:text-white"
          >{r}</button>
        ))}
      </div>
    )}
  </div>

  <TierTable entries={entries} />

  <script is:inline>
    (function () {
      const root = document.querySelector("[data-tier-table]");
      const filters = document.querySelector("[data-tier-filters]");
      if (!root || !filters) return;

      // Game filter is multi-select (set of active games). Default: all on.
      const allGames = new Set(
        Array.from(document.querySelectorAll("[data-game-chip]")).map((b) => b.dataset.value)
      );
      const activeGames = new Set(allGames);
      let activeRole = "all";

      const ACTIVE_CLS = ["bg-primary-600", "text-white"];
      const INACTIVE_CLS = ["bg-bg-soft", "text-gray-400"];
      function paint(btn, on) {
        btn.classList.toggle("bg-primary-600", on);
        btn.classList.toggle("text-white", on);
        btn.classList.toggle("bg-bg-soft", !on);
        btn.classList.toggle("text-gray-400", !on);
      }

      function applyFilter() {
        const entries = root.querySelectorAll("[data-tier-entry]");
        entries.forEach((el) => {
          const g = el.dataset.game || "nte";
          const roles = (el.dataset.roles || "").split("|").filter(Boolean);
          const gameOk = activeGames.has(g);
          const roleOk = activeRole === "all" || roles.includes(activeRole);
          el.classList.toggle("hidden", !(gameOk && roleOk));
        });
        // Empty-state per tier section.
        root.querySelectorAll("[data-tier-section]").forEach((sec) => {
          const visible = sec.querySelectorAll("[data-tier-entry]:not(.hidden)").length;
          const grid = sec.querySelector("[data-tier-grid]");
          const noMatch = sec.querySelector("[data-tier-no-match]");
          const empty = sec.querySelector("[data-tier-empty]");
          if (grid && noMatch) {
            const hasAny = sec.querySelectorAll("[data-tier-entry]").length > 0;
            if (!hasAny) return; // tier was empty server-side, leave the "coming soon" note
            noMatch.classList.toggle("hidden", visible > 0);
            grid.classList.toggle("hidden", visible === 0);
          }
        });
      }

      filters.querySelectorAll("[data-game-chip]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const v = btn.dataset.value;
          if (activeGames.has(v) && activeGames.size > 1) {
            activeGames.delete(v);
          } else if (activeGames.has(v)) {
            // Last active → clicking it again selects only it; nothing to do.
            return;
          } else {
            activeGames.add(v);
          }
          paint(btn, activeGames.has(v));
          applyFilter();
        });
      });

      filters.querySelectorAll("[data-role-chip]").forEach((btn) => {
        btn.addEventListener("click", () => {
          activeRole = btn.dataset.value || "all";
          filters.querySelectorAll("[data-role-chip]").forEach((b) => {
            paint(b, b.dataset.value === activeRole);
          });
          applyFilter();
        });
      });
    })();
  </script>


  {editorialItems.length > 0 && (
    <section class="mt-16">
      <h2 class="mb-4">Editorial Tier Lists</h2>
      <p class="text-sm text-gray-400 mb-6">
        Long-form ranking commentary from the editorial pipeline. These are
        produced as standalone articles and aggregated here.
      </p>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {editorialItems.map((it) => (
          <ArticleCard
            href={it.href}
            title={it.title}
            articleType="tier_list"
            qaScore={it.qaScore}
            wordCount={it.wordCount}
            publishedAt={it.publishedAt}
            heroImage={it.heroImage}
          />
        ))}
      </div>

      <div class="mt-10 space-y-12">
        {editorialItems.map(async (it) => {
          const { Content } = await it.body.render();
          return (
            <article id={`editorial-${it.body.slug}`} class="prose-game">
              <h3 class="mt-0">{it.title}</h3>
              <Content />
            </article>
          );
        })}
      </div>
    </section>
  )}

  {recentGuides.length > 0 && (
    <section class="mt-16">
      <h2 class="mb-2">Latest Guides &amp; Patch Coverage</h2>
      <p class="text-sm text-gray-400 mb-5">
        Fresh builds, comparisons, and patch breakdowns that feed into these
        rankings — updated as new banners and versions go live.
      </p>
      <ul class="grid gap-x-8 gap-y-2 sm:grid-cols-2">
        {recentGuides.map((g) => (
          <li class="border-b border-white/5 py-2">
            <a href={g.href} class="text-gray-300 hover:text-white">
              {g.title}
            </a>
            {g.publishedAt && (
              <span class="ml-2 text-xs text-gray-600">
                {new Date(g.publishedAt).toISOString().slice(0, 10)}
              </span>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="mt-12 prose-game">
    <h2>Why this ranking?</h2>
    <p>
      Tier placements reflect performance in <strong>Beyond the Rails</strong> and <strong>Fracture Circle</strong>
      endgame content, weighted across DPS output, elemental application uptime,
      utility, and resource efficiency at low Resonance. Rankings shift with each
      patch — see the per-character pages for current build advice.
    </p>
    <p class="text-sm text-gray-400">
      This is an early launch — the database expands daily as new content goes live.
      Each entry below is independently QA-scored against grounded search results.
    </p>
  </section>
</BaseLayout>
