---
import { getCollection, type CollectionEntry } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";

export async function getStaticPaths() {
  const all = await getCollection("weapons");
  return all.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<"weapons"> }
const { entry } = Astro.props;
const { Content, headings } = await entry.render();
---

<ArticleLayout
  title={entry.data.title}
  publishedAt={entry.data.published_at}
  qaScore={entry.data.qa_score}
  wordCount={entry.data.word_count}
  articleType={entry.data.article_type}
  heroImage={entry.data.hero_image}
  sources={entry.data.sources}
  slug={entry.slug}
  crumbs={[
    { href: "/", label: "Home" },
    { href: "/weapons", label: "Weapons" },
    { label: entry.data.title },
  ]}
  headings={headings}
  body={entry.body}
  quickAnswer={entry.data.quick_answer}
  affiliate={entry.data.affiliate}
>
  <Content />
</ArticleLayout>
