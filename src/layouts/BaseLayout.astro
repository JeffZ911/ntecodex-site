---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, any>;
  noindex?: boolean;
}

const {
  title,
  description = "NTE Codex — Neverness to Everness builds, tier list, character database and gacha guides.",
  ogImage,
  jsonLd,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site || "https://ntecodex.com").toString();
const adsensePub = import.meta.env.PUBLIC_ADSENSE_PUB_ID || "";
const adsClient = adsensePub
  ? (adsensePub.startsWith("ca-") ? adsensePub : `ca-${adsensePub}`)
  : "";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}

    {adsClient && adsensePub !== "pending" && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsClient}`}
        crossorigin="anonymous"
      ></script>
    )}
  </head>
  <body class="font-sans antialiased">
    <Header />
    <main class="container-page py-8">
      <slot />
    </main>
    <Footer />

    <!-- Lightweight cookie notice (no JS framework needed) -->
    <div
      id="cookie-notice"
      class="fixed bottom-4 right-4 left-4 sm:left-auto z-50 max-w-md rounded-lg border border-white/10 bg-bg-soft p-4 text-xs text-gray-300 shadow-glow-primary hidden"
    >
      <p class="m-0">
        We use cookies for analytics and ads. By continuing you accept our
        <a href="/privacy" class="underline">privacy policy</a>.
      </p>
      <button
        id="cookie-ok"
        class="mt-2 rounded-md bg-primary-600 px-3 py-1.5 font-semibold text-white hover:bg-primary-500"
      >
        Got it
      </button>
    </div>
    <script is:inline>
      (function () {
        try {
          if (!localStorage.getItem("cookie-ok")) {
            const el = document.getElementById("cookie-notice");
            if (el) el.classList.remove("hidden");
          }
          const btn = document.getElementById("cookie-ok");
          btn && btn.addEventListener("click", function () {
            localStorage.setItem("cookie-ok", "1");
            const el = document.getElementById("cookie-notice");
            if (el) el.classList.add("hidden");
          });
        } catch (e) {}
      })();
    </script>
  </body>
</html>
