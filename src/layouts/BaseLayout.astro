---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, any>;
  noindex?: boolean;
}

const {
  title,
  description = "Gacha Codex — Neverness to Everness builds, tier list, character database and gacha guides.",
  ogImage,
  jsonLd,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site || "https://ntecodex.com").toString();
// AdSense publisher id is public (also lives in /ads.txt). Default it
// here so build does not depend on .env being present.
const adsensePub =
  import.meta.env.PUBLIC_ADSENSE_PUB_ID || "pub-5523706123080113";
const adsClient = adsensePub
  ? (adsensePub.startsWith("ca-") ? adsensePub : `ca-${adsensePub}`)
  : "";

// GA4 measurement id is public (visible in page source on every analytics
// site). Default for build without .env, override via CF Pages env.
const gaId =
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID || "G-FBQDFV7CXF";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Inter is shipped by Cloudflare's CDN font hosting via /cf-fonts/,
         loaded through the @font-face block injected at build time by
         Cloudflare Pages. We do NOT need the Google Fonts <link> request
         — it was a leftover from before the CF font-injection landed and
         was costing ~200ms on mobile cold-load. Removed. -->

    <!-- Preconnect to 3rd-party origins that *will* be hit by the deferred
         AdSense + GA4 loaders below, so their DNS+TCP+TLS happens in
         parallel with the document parse instead of serially after. -->
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />

    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}

    <!-- AdSense + GA4 are NOT critical for first paint. Boot them after
         the page is idle (or after first user interaction, whichever is
         first) so they don't compete with LCP for CPU + bandwidth on
         slow networks. Both still load as `async` once started, and the
         loader URLs/IDs are baked in at build time (public values).

         Trade-off: GA4 will miss the first ~1-3 seconds of pageviews
         that bounce instantly. Acceptable — those bounces aren't useful
         analytics anyway, and the mobile LCP win outweighs them. -->
    {(adsClient && adsensePub !== "pending") || gaId ? (
      <script is:inline set:html={`
        (function () {
          var booted = false;
          function boot() {
            if (booted) return;
            booted = true;
            ${adsClient && adsensePub !== "pending" ? `
            var ad = document.createElement('script');
            ad.async = true;
            ad.crossOrigin = 'anonymous';
            ad.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsClient}';
            document.head.appendChild(ad);
            ` : ''}
            ${gaId ? `
            var ga = document.createElement('script');
            ga.async = true;
            ga.src = 'https://www.googletagmanager.com/gtag/js?id=${gaId}';
            document.head.appendChild(ga);
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', '${gaId}', { anonymize_ip: true });
            ` : ''}
          }
          // Boot when the browser is idle, OR after first user interaction,
          // whichever comes first. Cap at 4s so analytics still fire for
          // patient readers.
          if ('requestIdleCallback' in window) {
            requestIdleCallback(boot, { timeout: 4000 });
          } else {
            setTimeout(boot, 2500);
          }
          ['scroll','keydown','pointerdown','touchstart'].forEach(function (ev) {
            window.addEventListener(ev, boot, { once: true, passive: true });
          });
        })();
      `}></script>
    ) : null}
  </head>
  <body class="font-sans antialiased">
    <Header />
    <main class="container-page py-8">
      <slot />
    </main>
    <Footer />

    <!-- Cookie consent is handled by Google's CMP (Consent Management
         Platform) which is injected by the AdSense loader. We previously had
         a hand-rolled banner here; that's been removed so it doesn't shadow
         the CMP's GDPR-compliant Consent / Manage / Decline dialog. -->

  </body>
</html>
