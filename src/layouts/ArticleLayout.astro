---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import SourceList from "../components/SourceList.astro";
import CommentSection from "../components/CommentSection.astro";
import RelatedGuides from "../components/RelatedGuides.astro";
import TableOfContents from "../components/TableOfContents.astro";

interface Crumb { href?: string; label: string }
interface Heading { depth: number; slug: string; text: string }
interface Props {
  title: string;
  description?: string;
  publishedAt?: string;
  qaScore?: number;
  wordCount?: number;
  articleType: string;
  heroImage?: string;
  sources?: any[];
  crumbs: Crumb[];
  /** Article slug — used to scope the comment section to this article. */
  slug?: string;
  /** Set true (typically via frontmatter `affiliate: true`) when the
   * article body contains affiliate links. Renders a top-of-article FTC
   * disclosure banner and signals to readers / search engines that the
   * page has commercial intent. */
  affiliate?: boolean;
  /** 1-2 sentence answer-up-front callout (frontmatter `quick_answer`).
   * When present, renders as a highlighted card at the very top of the
   * body — readers get the answer immediately instead of scrolling. */
  quickAnswer?: string;
  /** Markdown headings from `entry.render().headings`. When passed in,
   * renders a sticky right-side TOC on xl+ screens (≥1280px). */
  headings?: Heading[];
  /** Raw markdown body (entry.body) — used to derive FAQPage JSON-LD from the
   * `## Frequently Asked Questions` section the writer emits. */
  body?: string;
}

const {
  title, description, publishedAt, qaScore, wordCount,
  articleType, heroImage, sources = [], crumbs, slug,
  affiliate = false, quickAnswer, headings = [], body = "",
} = Astro.props;

const dateStr = publishedAt
  ? new Date(publishedAt).toISOString().slice(0, 10)
  : null;

// Quality-gate noindex (content-pruning, 2026-05-25): a young domain bloated
// with low-tier mass content gets the WHOLE site suppressed (scaled-content
// signal) + fails AdSense. noindex the strong-tier band (qa_score < 6.0) so
// only the better ~275 pages stay indexable, lifting the site's quality
// signal. Reversible — change the threshold. noindex,follow keeps link equity.
const NOINDEX_BELOW = 6.0;
// Authority concentration (2026-06-17): affiliate "best X for Y" gear roundups
// average 2 impressions/page vs 18 for real game content (9× worse) and earn
// ~0 clicks, yet their mass dilutes the site's topical authority + scaled-
// content signal. noindex,follow them so crawl/quality signal concentrates on
// the game guides; link equity still flows and the URLs stay live (no 404s).
const noindex = (qaScore != null && qaScore < NOINDEX_BELOW) || affiliate === true;

// JSON-LD: brand-author + publishingPrinciples / actionableFeedbackPolicy
// fields are Google's documented E-E-A-T signals — pointing them at
// /editorial-policy and /contact gives the reviewer a machine-readable
// trust trail without inventing a fictional human author.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  datePublished: publishedAt,
  dateModified: publishedAt,
  author: {
    "@type": "Organization",
    name: "Gacha Codex Editorial",
    url: "https://ntecodex.com/about",
  },
  publisher: {
    "@type": "Organization",
    name: "Gacha Codex",
    url: "https://ntecodex.com/",
  },
  publishingPrinciples: "https://ntecodex.com/editorial-policy",
  actionableFeedbackPolicy: "https://ntecodex.com/contact",
  description: description,
  ...(heroImage ? { image: heroImage } : {}),
};

// FAQPage JSON-LD — parsed from the writer-emitted `## Frequently Asked
// Questions` section (### question + answer paragraphs). Rich-result
// eligibility for the PAA/FAQ surface; emitted alongside the Article object.
const faqMatch = body.match(/^##\s+Frequently Asked Questions\s*$([\s\S]*?)(?=^##\s|(?![\s\S]))/m);
const faqEntities = [];
if (faqMatch) {
  const sect = faqMatch[1];
  const qa = [...sect.matchAll(/^###\s+(.+)$([\s\S]*?)(?=^###\s|(?![\s\S]))/gm)];
  for (const m of qa) {
    const q = m[1].trim();
    const a = m[2].replace(/\s+/g, " ").trim().slice(0, 600);
    if (q && a) faqEntities.push({
      "@type": "Question", name: q,
      acceptedAnswer: { "@type": "Answer", text: a },
    });
  }
}
const jsonLdOut = faqEntities.length
  ? [jsonLd, { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqEntities }]
  : jsonLd;
---

<BaseLayout title={title} description={description} ogImage={heroImage} jsonLd={jsonLdOut} noindex={noindex}>
  <Breadcrumb crumbs={crumbs} />

  {/* 2-column layout on xl+: main article + sticky TOC sidebar.
      On <xl screens the TOC is `hidden`, so the grid collapses to a
      single column visually (the empty 2nd col is harmless). */}
  <div class="xl:grid xl:grid-cols-[minmax(0,1fr)_14rem] xl:gap-10">
    <article class="prose-game max-w-none min-w-0">
      {heroImage && (
        <img src={heroImage} alt={title}
             width="1280" height="720"
             fetchpriority="high"
             class="mb-6 aspect-video w-full max-h-[400px] rounded-xl object-cover" />
      )}

      <header class="mb-6">
        <div class="flex flex-wrap items-center gap-2 text-xs text-gray-400">
          <span class="rounded bg-primary-700/30 px-2 py-0.5 capitalize text-primary-100">
            {articleType.replace("_", " ")}
          </span>
          {dateStr && <span>{dateStr}</span>}
          {wordCount != null && <span>· {wordCount.toLocaleString()} words</span>}
        </div>
        <h1 class="mt-3 text-balance">{title}</h1>
      </header>

      <div class="min-w-0">
        {affiliate && (
          <aside class="mb-6 rounded-lg border border-amber-400/20 bg-amber-500/5 px-4 py-3 text-sm text-amber-100/90">
            <strong class="text-amber-200">Affiliate disclosure:</strong>
            This article contains affiliate links. If you buy through them,
            we may earn a small commission at no cost to you. Recommendations
            are made independently — see our
            <a href="/affiliate-disclosure" class="underline hover:text-amber-50">Affiliate Disclosure</a>
            and <a href="/editorial-policy" class="underline hover:text-amber-50">Editorial Policy</a>.
          </aside>
        )}
        {quickAnswer && (
          <aside class="mb-6 rounded-xl border border-primary-400/30 bg-primary-900/20 px-5 py-4">
            <p class="m-0 text-xs font-semibold uppercase tracking-wider text-primary-300">
              Quick answer
            </p>
            <p class="mt-2 mb-0 text-base text-gray-100">{quickAnswer}</p>
          </aside>
        )}
        <slot />
        {slug && <RelatedGuides currentSlug={slug} articleType={articleType} />}
        <SourceList sources={sources} />
        {slug && <CommentSection articleSlug={slug} />}
      </div>
    </article>

    <TableOfContents headings={headings} />
  </div>
</BaseLayout>
