---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import SourceList from "../components/SourceList.astro";
import AdSlot from "../components/AdSlot.astro";
import CommentSection from "../components/CommentSection.astro";

interface Crumb { href?: string; label: string }
interface Props {
  title: string;
  description?: string;
  publishedAt?: string;
  qaScore?: number;
  wordCount?: number;
  articleType: string;
  heroImage?: string;
  sources?: any[];
  crumbs: Crumb[];
  /** Article slug — used to scope the comment section to this article. */
  slug?: string;
}

const {
  title, description, publishedAt, qaScore, wordCount,
  articleType, heroImage, sources = [], crumbs, slug,
} = Astro.props;

const dateStr = publishedAt
  ? new Date(publishedAt).toISOString().slice(0, 10)
  : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  datePublished: publishedAt,
  dateModified: publishedAt,
  // E-E-A-T-friendly independent-creator pattern: a named editorial Person
  // as author, NTE Codex as a lightweight publisher Organization (no logo
  // / no address / no fictional corporate claim).
  author: { "@type": "Person", name: "NTE Codex Editorial" },
  publisher: { "@type": "Organization", name: "NTE Codex" },
  description: description,
  ...(heroImage ? { image: heroImage } : {}),
};
---

<BaseLayout title={title} description={description} ogImage={heroImage} jsonLd={jsonLd}>
  <Breadcrumb crumbs={crumbs} />

  <article class="prose-game max-w-none">
    {heroImage && (
      <img src={heroImage} alt=""
           width="1280" height="720"
           fetchpriority="high"
           class="mb-6 aspect-video w-full rounded-xl object-cover" />
    )}

    <header class="mb-6">
      <div class="flex flex-wrap items-center gap-2 text-xs text-gray-400">
        <span class="rounded bg-primary-700/30 px-2 py-0.5 capitalize text-primary-100">
          {articleType.replace("_", " ")}
        </span>
        {dateStr && <span>{dateStr}</span>}
        {wordCount != null && <span>· {wordCount.toLocaleString()} words</span>}
        {qaScore != null && (
          <span class="flex items-center gap-1">
            · <span class="text-gold">●</span>
            <span>{qaScore.toFixed(1)} / 10 QA</span>
          </span>
        )}
      </div>
      <h1 class="mt-3 text-balance">{title}</h1>
    </header>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px]">
      <div class="min-w-0">
        <slot />
        <SourceList sources={sources} />
        {slug && <CommentSection articleSlug={slug} />}
      </div>
      <aside class="space-y-6 lg:sticky lg:top-20 self-start">
        <AdSlot />
        <div class="card text-sm">
          <h3 class="mt-0 text-xs font-semibold uppercase tracking-wider text-primary-300">
            About this guide
          </h3>
          <p class="text-gray-300 m-0">
            Generated and quality-reviewed by AI with Google Search grounding.
            Score reflects six dimensions including factual accuracy.
          </p>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
