---
interface Source {
  uri: string;
  title?: string;
}
interface Props {
  sources?: (string | Source)[];
}
const { sources = [] } = Astro.props;

const cleaned: Source[] = sources
  .map((s) => (typeof s === "string" ? { uri: s } : s))
  .filter((s) => s && s.uri);

function hostnameOf(uri: string): string {
  try {
    return new URL(uri).hostname.replace(/^www\./, "");
  } catch {
    return uri;
  }
}
---

{cleaned.length > 0 && (
  <details class="mt-10 rounded-lg border border-white/5 bg-bg-soft/40 p-4 group">
    <summary class="cursor-pointer text-sm font-semibold text-primary-200 list-none flex items-center gap-2">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           class="transition-transform group-open:rotate-90">
        <path d="m9 18 6-6-6-6"/>
      </svg>
      <span>Sources ({cleaned.length})</span>
    </summary>
    <ul class="mt-3 list-none p-0 space-y-1.5 text-sm">
      {cleaned.map((s) => (
        <li class="truncate">
          <a href={s.uri} target="_blank" rel="nofollow noopener"
             class="text-gray-300 hover:text-white">
            {s.title || hostnameOf(s.uri)}
          </a>
          <span class="ml-2 text-xs text-gray-500">{hostnameOf(s.uri)}</span>
        </li>
      ))}
    </ul>
  </details>
)}
