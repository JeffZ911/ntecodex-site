---
import Search from "./Search.astro";

const nav = [
  { href: "/tier-list", label: "Tier List" },
  { href: "/characters", label: "Characters" },
  { href: "/guides", label: "Guides" },
  { href: "/banners/current", label: "Banners" },
  { href: "/faq", label: "FAQ" },
];
---

<header class="sticky top-0 z-30 border-b border-white/5 bg-bg/80 backdrop-blur">
  <div class="container-page flex h-14 items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline text-white hover:text-primary-200">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-primary-600 text-sm font-bold shadow-glow-primary">N</span>
      <span class="font-display text-lg font-bold tracking-tight">NTE Codex</span>
    </a>
    <nav class="hidden md:flex items-center gap-1 text-sm">
      {nav.map((n) => (
        <a
          href={n.href}
          class="rounded-md px-3 py-2 text-gray-300 no-underline hover:bg-white/5 hover:text-white"
        >
          {n.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <Search />
    </div>
  </div>
</header>
