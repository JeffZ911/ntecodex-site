---
// ProductCard — single product card for "best X for Y" round-ups and
// comparison pages. Renders image / rating / price / pros / cons / a
// big "Check on Amazon" CTA marked rel="sponsored" so search engines
// (and our own users) can identify it as a paid placement.
//
// All fields are optional except `name`; missing fields just skip
// their slot rather than rendering "undefined". Designed to be cheap
// to populate manually OR from PA-API once Amazon Associates is live.

interface Props {
  rank?: number;
  name: string;
  image?: string;
  price_usd?: number;
  rating?: number;
  review_count?: number;
  pros?: string[];
  cons?: string[];
  best_for?: string;
  affiliate_url?: string;
  asin?: string;
  verdict?: string;
}
const {
  rank, name, image, price_usd, rating, review_count,
  pros = [], cons = [], best_for, affiliate_url, asin, verdict,
} = Astro.props;

// Compose final outbound URL — prefer explicit affiliate_url, else
// build a tagged Amazon URL from ASIN. Tag value matches the central
// brand config; if you change it, change it here too (jeffzen911-20).
const AMAZON_TAG = "jeffzen911-20";
const href =
  affiliate_url ||
  (asin ? `https://www.amazon.com/dp/${asin}?tag=${AMAZON_TAG}` : null);

// 5-star renderer. Half-stars are floored — we round to nearest 0.5.
function starsFor(r: number) {
  const half = Math.round(r * 2) / 2;
  const full = Math.floor(half);
  const has_half = half - full === 0.5;
  return { full, has_half, empty: 5 - full - (has_half ? 1 : 0) };
}
const stars = rating != null ? starsFor(rating) : null;
---

<article class="product-card relative flex flex-col gap-4 rounded-2xl border border-white/5 bg-bg-soft/40 p-5 md:flex-row">
  {rank && (
    <span class="absolute -top-3 -left-2 flex h-9 w-9 items-center justify-center rounded-full bg-primary-600 text-sm font-bold text-white shadow-glow-primary">
      #{rank}
    </span>
  )}

  {image && (
    <div class="w-full shrink-0 md:w-48">
      <img
        src={image}
        alt={name}
        width="320"
        height="320"
        loading="lazy"
        decoding="async"
        class="aspect-square w-full rounded-xl object-contain bg-white/5 p-2"
      />
    </div>
  )}

  <div class="flex-1 min-w-0 flex flex-col">
    <header>
      {best_for && (
        <p class="m-0 text-xs font-semibold uppercase tracking-wider text-primary-300">
          Best for {best_for}
        </p>
      )}
      <h3 class="mt-1 mb-0 text-lg font-semibold text-white">{name}</h3>

      <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
        {stars && (
          <span class="flex items-center gap-1" aria-label={`Rated ${rating} out of 5`}>
            <span class="text-amber-400" aria-hidden="true">
              {"★".repeat(stars.full)}{stars.has_half ? "⯨" : ""}
              <span class="text-amber-400/30">{"★".repeat(stars.empty)}</span>
            </span>
            <span class="text-gray-300">{rating?.toFixed(1)}</span>
            {review_count != null && (
              <span class="text-gray-500">({review_count.toLocaleString()})</span>
            )}
          </span>
        )}
        {price_usd != null && (
          <span class="text-emerald-300 font-semibold">${price_usd.toFixed(0)}</span>
        )}
      </div>
    </header>

    {verdict && (
      <p class="mt-3 mb-0 text-sm text-gray-300">{verdict}</p>
    )}

    {(pros.length > 0 || cons.length > 0) && (
      <div class="mt-3 grid gap-3 sm:grid-cols-2 text-sm">
        {pros.length > 0 && (
          <div>
            <p class="m-0 text-xs font-semibold uppercase tracking-wider text-emerald-300">Pros</p>
            <ul class="mt-1 mb-0 list-none space-y-1 p-0">
              {pros.map((p) => (
                <li class="flex gap-2 text-gray-200">
                  <span class="text-emerald-400" aria-hidden="true">+</span><span>{p}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        {cons.length > 0 && (
          <div>
            <p class="m-0 text-xs font-semibold uppercase tracking-wider text-rose-300">Cons</p>
            <ul class="mt-1 mb-0 list-none space-y-1 p-0">
              {cons.map((c) => (
                <li class="flex gap-2 text-gray-200">
                  <span class="text-rose-400" aria-hidden="true">−</span><span>{c}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}

    {href && (
      <div class="mt-4">
        <a
          href={href}
          rel="sponsored noopener nofollow"
          target="_blank"
          class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-gray-900 no-underline hover:bg-amber-400"
        >
          Check on Amazon
          <span aria-hidden="true">→</span>
        </a>
        <p class="m-0 mt-2 text-xs text-gray-500">
          Affiliate link · Price subject to change · We may earn a commission
        </p>
      </div>
    )}
  </div>
</article>
