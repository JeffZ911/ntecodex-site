---
// ProductRoundup — top-of-article wrapper that renders all frontmatter
// `products` as a stacked list of <ProductCard>s plus a quick-jump
// comparison table. This is the "best X for Y" pattern that converts —
// readers see the verdicts up-front and can scroll to the detailed
// reasoning in the prose body below.
//
// Gated by a build-time env kill-switch: setting `AFFILIATE_EMBED_ENABLED=false`
// on Cloudflare Pages suppresses all affiliate UI globally without
// touching content — useful before Amazon Associates approval lands.

import ProductCard from "./ProductCard.astro";

interface Product {
  name: string;
  asin?: string;
  image?: string;
  price_usd?: number;
  rating?: number;
  review_count?: number;
  pros?: string[];
  cons?: string[];
  best_for?: string;
  affiliate_url?: string;
  verdict?: string;
}

interface Props {
  products: Product[];
}

const { products } = Astro.props;

// Build-time kill-switch. Default ON; set to "false"/"0"/"no" to suppress.
const enabledRaw = (import.meta.env.AFFILIATE_EMBED_ENABLED || "true").toString().toLowerCase();
const enabled = !["false", "0", "no", "off"].includes(enabledRaw);

const show = enabled && products && products.length > 0;
---

{show && (
  <section class="not-prose mb-10 space-y-6">
    {/* Quick comparison table — name / best-for / rating / price / jump.
        Sticky for long round-ups; lets readers compare at a glance before
        scrolling into individual product detail cards. */}
    {products.length > 1 && (
      <div class="overflow-x-auto rounded-xl border border-white/5 bg-bg-soft/30">
        <table class="w-full text-sm">
          <thead class="text-left text-xs uppercase tracking-wider text-gray-500">
            <tr>
              <th class="px-4 py-3 font-medium">#</th>
              <th class="px-4 py-3 font-medium">Product</th>
              <th class="px-4 py-3 font-medium">Best for</th>
              <th class="px-4 py-3 font-medium">Rating</th>
              <th class="px-4 py-3 font-medium">Price</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {products.map((p, i) => (
              <tr>
                <td class="px-4 py-3 font-mono text-primary-200">{i + 1}</td>
                <td class="px-4 py-3 text-gray-100">
                  <a href={`#product-${i + 1}`} class="no-underline hover:text-primary-200">
                    {p.name}
                  </a>
                </td>
                <td class="px-4 py-3 text-gray-400">{p.best_for || "—"}</td>
                <td class="px-4 py-3 text-amber-300">
                  {p.rating != null ? `★ ${p.rating.toFixed(1)}` : "—"}
                </td>
                <td class="px-4 py-3 text-emerald-300">
                  {p.price_usd != null ? `$${p.price_usd.toFixed(0)}` : "—"}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {/* Stack of product detail cards. Each gets an id so the
        comparison table above can jump to it. */}
    <div class="space-y-5">
      {products.map((p, i) => (
        <div id={`product-${i + 1}`} class="scroll-mt-20">
          <ProductCard rank={i + 1} {...p} />
        </div>
      ))}
    </div>
  </section>
)}
